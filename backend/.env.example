# ── Django Core ───────────────────────────────────────────────────────────────
SECRET_KEY=<generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())">
DEBUG=False
ALLOWED_HOSTS=ardhitrust.co.ke,www.ardhitrust.co.ke
BASE_URL=https://ardhitrust.co.ke
APP_VERSION=1.0.0

# ── Database ──────────────────────────────────────────────────────────────────
# Development:  postgres://ardhitrust:password@localhost:5432/ardhitrust
# Production:   postgres://ardhitrust:password@pgbouncer:6432/ardhitrust  ← PgBouncer port
DATABASE_URL=postgres://user:pass@pgbouncer:6432/ardhitrust

# Read replica — point to RDS replica endpoint in production
# Development:  same as DATABASE_URL (fallback to primary)
DATABASE_REPLICA_URL=postgres://user:pass@db_replica:5432/ardhitrust

# Raw passwords used by PgBouncer and PostgreSQL containers
DB_PASSWORD=
REPLICATION_PASSWORD=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:password@host:6379/0
REDIS_PASSWORD=

# ── AWS S3 ────────────────────────────────────────────────────────────────────
# Used for: document uploads AND audit log archiving (FIX 3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=ardhitrust-documents
AWS_S3_REGION_NAME=af-south-1

# ── PII Field Encryption ──────────────────────────────────────────────────────
# CRITICAL: Set this BEFORE the first migration. Changing it after
# breaks all existing encrypted data (national IDs, KRA PINs).
# Generate key: python -c "import secrets; print(secrets.token_hex(32))"
# Rotation: add new key at the front, keep old key at the back for decryption
FIELD_ENCRYPTION_KEYS=current_key,old_key_for_decryption

# ── M-Pesa Daraja ─────────────────────────────────────────────────────────────
MPESA_ENV=production
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_INITIATOR_NAME=
MPESA_SECURITY_CREDENTIAL=

# ── External Verification APIs ────────────────────────────────────────────────
ARDHISASA_API_URL=https://api.ardhisasa.lands.go.ke
ARDHISASA_API_KEY=
ARDHISASA_MOCK_MODE=False
IPRS_API_URL=https://api.iprs.go.ke
IPRS_API_KEY=
IPRS_MOCK_MODE=False
KRA_API_URL=https://api.kra.go.ke
KRA_API_KEY=

# ── AI ────────────────────────────────────────────────────────────────────────
# Set a monthly spending cap in the Anthropic dashboard to match expected volume.
# At 10/min throttle per user: 10k users peak = ~$75/month, 100k = ~$750/month
ANTHROPIC_API_KEY=sk-ant-...

# ── Notifications ─────────────────────────────────────────────────────────────
AFRICAS_TALKING_USERNAME=
AFRICAS_TALKING_API_KEY=
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=email-smtp.af-south-1.amazonaws.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://ardhitrust.co.ke,https://www.ardhitrust.co.ke,https://ardhitrust-mxnl.vercel.app

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=
